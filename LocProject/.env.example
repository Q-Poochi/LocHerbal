# Database Connection URL (PgBouncer port 6432 for normal app queries, transaction pooling mode)
# Use pgbouncer=true to let Prisma know it is connecting through a transaction pooler.
DATABASE_URL="postgresql://postgres:postgres_password@localhost:6432/ecommerce?pgbouncer=true&connection_limit=10"

# Direct Database Connection URL (Postgres Primary port 5434 for migrations, session mode)
# Migrations and DDL statements must connect directly to bypass the PgBouncer pooler.
DIRECT_URL="postgresql://postgres:postgres_password@localhost:5434/ecommerce"
